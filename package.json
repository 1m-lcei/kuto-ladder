    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "daisyui": "^5.6.17",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~7.0.2",
